{
  "name": "Projet-Canis-Pro",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/Projet-Canis-Pro",
  // Ajoute cette section :
  "forwardPorts": [8000, 8080], 
  "portsAttributes": {
    "8080": {
      "label": "phpMyAdmin",
      "onAutoForward": "openBrowserPreview" 
    },
    "8000": {
      "label": "Symfony",
      "onAutoForward": "openBrowserPreview" 
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "symfony server:start --allow-http --port=8000 --no-tls --daemon"
}