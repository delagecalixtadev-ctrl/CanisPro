{% if is_granted('ROLE_ADMIN') %}
<form method="post" action="{{ path('adminSupprimerUneInscription', {'id': inscription.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inscription.id) }}">
    <button class="btn">Delete</button>
</form>
{% else %}
    <form method="post" action="{{ path('membreSuppressionInscription', {'id': inscription.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inscription.id) }}">
    <button class="btn">Delete</button>
</form>        
{% endif %} 

