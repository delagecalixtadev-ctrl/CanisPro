{% extends 'base.html.twig' %}

{% block title %}NiveauApprentissage index{% endblock %}

{% block body %}
    <h1>NiveauApprentissage index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Libelle</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for niveau_apprentissage in niveau_apprentissages %}
            <tr>
                <td>{{ niveau_apprentissage.id }}</td>
                <td>{{ niveau_apprentissage.libelle }}</td>
                <td>
                    <a href="{{ path('adminAfficheUnNiveauApprentissage', {'id': niveau_apprentissage.id}) }}">show</a>
                    <a href="{{ path('adminModifierUnNiveauApprentissage', {'id': niveau_apprentissage.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('adminAjoutNiveauApprentissage') }}">Create new</a>
{% endblock %}
