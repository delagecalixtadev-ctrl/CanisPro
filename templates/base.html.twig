<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
        <link rel="icon" type="image/x-icon" href="{{ asset('/favicon.ico') }}">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        <style>
            /* Style du bouton retour en haut */
            #backToTop {
                display: none; /* Caché par défaut */
                position: fixed;
                bottom: 30px;
                right: 30px;
                z-index: 9999;
                border: none;
                outline: none;
                background-color: #5e8d93; /* Couleur CanisPro */
                color: white;
                cursor: pointer;
                padding: 10px;
                border-radius: 50%;
                width: 50px;
                height: 50px;
                box-shadow: 0px 4px 10px rgba(0,0,0,0.3);
                transition: all 0.3s ease;
                font-size: 24px;
                line-height: 1;
            }

            #backToTop:hover {
                background-color: #385656;
                transform: scale(1.1);
            }
        </style>
    </head>
    <body>
        {% include "menu.html.twig"%}
        
        {% block body %}{% endblock %}

        <button id="backToTop" title="Retour en haut">▲</button>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        
        <script>
            const btnTop = document.getElementById("backToTop");

            // Affiche le bouton quand on descend de 400px
            window.onscroll = function() {
                if (document.body.scrollTop > 400 || document.documentElement.scrollTop > 400) {
                    btnTop.style.display = "block";
                } else {
                    btnTop.style.display = "none";
                }
            };

            // Remontée fluide au clic
            btnTop.onclick = function() {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            };
        </script>
    </body>
</html>