{% extends 'base.html.twig' %}

{% block title %}Hello MembreController!{% endblock %}

{% block body %}
<style>
/* --- Reset & Bases --- */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: white;
    font-family: 'Montserrat', sans-serif;
    color: #333;
}

.canispro-courses {
    padding-top: 50px;
}

/* --- Grille des Cartes --- */
.courses-container {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto 60px auto;
    padding: 0 20px;
}

.course-card {
    flex: 1;
    text-align: center;
}

/* En-tête des cartes */
.card-header {
    height: 400px;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
}

.category {
    font-size: 0.75rem;
    letter-spacing: 2px;
    margin-bottom: 5px;
    opacity: 0.8;
}

.card-title {
    font-family: 'Great Vibes', cursive;
    font-size: 3.5rem;
    font-weight: 400;
    margin: 10px 0;
}

.separator {
    width: 85%;
    border: 0;
    border-top: 1px solid rgba(0,0,0,0.1);
    margin: 10px 0;
}

.bg-blue .separator, 
.bg-brown .separator {
    border-top: 1px solid rgba(255,255,255,0.3);
}

.type {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 25px;
}

/* Description sous la carte */
.card-desc {
    margin-top: 25px;
    font-size: 0.9rem;
    line-height: 1.6;
    color: #666;
    padding: 0 10px;
}

/* --- Variantes de Couleurs --- */
.bg-blue { background-color: #548496; color: white; }
.bg-brown { background-color: #bc8a5f; color: white; }
.bg-white { 
    background-color: white; 
    color: #548496; 
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
}
.text-dark { color: #222; }

/* --- Boutons cliquables --- */
.btn {
    text-decoration: none;
    padding: 12px 25px;
    border-radius: 30px;
    font-size: 0.8rem;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-block;
}

.btn-white { background-color: white; color: #548496; }
.btn-white:hover { background-color: #f8f8f8; transform: translateY(-2px); }

.btn-blue { background-color: #548496; color: white; }
.btn-blue:hover { background-color: #3d6372; transform: translateY(-2px); }

.btn-outline-white { border: 1.5px solid white; color: white; }
.btn-outline-white:hover { background-color: white; color: #bc8a5f; }

.full-width-img {
    width: 100%;
    height: auto;
    display: block;
}

/* --- Responsive (Tablettes et Mobiles) --- */
@media (max-width: 992px) {
    .courses-container {
        flex-direction: column;
        align-items: center;
        gap: 50px;
    }
    .course-card {
        width: 100%;
        max-width: 450px;
    }
}
</style>

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CanisPro - Nos Cours</title>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

<main class="canispro-courses">
    
    <section class="courses-container">
        
        <div class="course-card">
            <div class="card-header bg-blue">
                <span class="category">COURS DE</span>
                <h2 class="card-title">Sociabilisation</h2>
                <hr class="separator">
                <span class="type">INDIVIDUEL OU COLLECTIF</span>
                <a href="{{ path('app_seance')}}" class="btn btn-white">Voir les séances disponibles</a>
            </div>
            <p class="card-desc">
                Les cours de sociabilisation permettent à l'animal d'acquérir les codes de communication et d'adapter ses réactions pour vivre harmonieusement avec son entourage.
            </p>
        </div>

        <div class="course-card">
            <div class="card-header bg-white">
                <span class="category">COURS D'</span>
                <h2 class="card-title text-dark">Obéissance</h2>
                <hr class="separator">
                <span class="type">INDIVIDUEL OU COLLECTIF</span>
                <a href="{{ path('app_seance')}}" class="btn btn-blue">Voir les séances disponibles</a>
            </div>
            <p class="card-desc">
                Un cours d'obéissance structuré lui apprend à se concentrer et à rester calme, même dans un environnement mouvementé.
            </p>
        </div>

        <div class="course-card">
            <div class="card-header bg-brown">
                <span class="category">COURS D'</span>
                <h2 class="card-title">Agilité</h2>
                <hr class="separator">
                <span class="type">INDIVIDUEL OU COLLECTIF</span>
                <a href="{{ path('app_seance')}}" class="btn btn-outline-white">Voir les séances disponibles</a>
            </div>
            <p class="card-desc">
                L'entraînement régulier sur un parcours d'agility améliore la condition physique du chien : il développe sa souplesse, son endurance, son équilibre et sa vitesse.
            </p>
        </div>

    </section>

</main>

</body>
</html>
{% endblock %}
