{% extends 'base.html.twig' %}

{% block title %}Confirmation Inscription{% endblock %}

{% block body %}
<style>
    body{
        background-color: white;
    }
    .conf-container {
        max-width: 800px;
        margin: 40px auto;
        font-family: 'Segoe UI', sans-serif;
    }

    /* Message de succès avec style "badge" */
    .success-banner {
        background-color: #f0f9f4;
        border-left: 5px solid #4caf50;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
        margin-bottom: 30px;
    }

    .success-banner h1 {
        color: #2e7d32;
        font-family: 'Apple Chancery', 'Segoe Print', cursive;
        margin: 0;
    }

    /* Carte récapitulative de la séance */
    .recap-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        margin-bottom: 40px;
        position: relative;
    }

    .recap-card::after {
        content: '🐾';
        position: absolute;
        bottom: 10px;
        right: 20px;
        font-size: 2rem;
        opacity: 0.1;
    }

    .recap-title {
        color: #7baeb5;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
        margin-bottom: 15px;
        display: block;
    }

    .recap-detail {
        font-size: 1.2rem;
        color: #333;
        margin: 10px 0;
    }

    /* Section "Mes autres chiens" plus discrète */
    .other-dogs-section {
        background: #f8fbfc;
        padding: 20px;
        border-radius: 12px;
        margin-top: 20px;
    }

    .dog-pill {
        display: inline-block;
        background: white;
        border: 1px solid #d1e3e5;
        padding: 5px 15px;
        border-radius: 20px;
        margin: 5px;
        font-size: 0.9rem;
    }

    .level-tag {
        color: #7baeb5;
        font-weight: bold;
        font-size: 0.8rem;
    }

    .btn-return {
        display: inline-block;
        margin-top: 25px;
        color: #7baeb5;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-return:hover {
        text-decoration: underline;
    }
</style>

<div class="conf-container">
    
    <div class="success-banner">
        <h1>Inscription réussie !</h1>
        <p>C'est noté, nous avons hâte de vous voir.</p>
    </div>

    <div class="recap-card">
        <span class="recap-title">Récapitulatif de la réservation</span>
        
        <p class="recap-detail">
            <strong>Cours :</strong> {{ inscription.seances|first.cours }}
        </p>
        <p class="recap-detail">
            <strong>Date :</strong> {{ inscription.seances|first.date|date('d/m/Y') }} 
            à {{ inscription.seances|first.heure|date('H:i') }}
        </p>
        <p class="recap-detail">
            <strong>Chien inscrit :</strong> {{ inscription.chiens|first.nom }}
        </p>
    </div>

    {% if proprietaire and proprietaire.chiens|length > 0 %}
        <div class="other-dogs-section">
            <h5 style="margin-top:0; color: #555;">Rappel de votre meute :</h5>
            {% for chien in proprietaire.chiens %}
                <div class="dog-pill">
                    {{ chien.nom }} 
                    <span class="level-tag">({{ chien.niveaux_apprentissage ? chien.niveaux_apprentissage.nom : 'Niveau non défini' }})</span>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <a href="{{ path('membre_mes_seances') }}" class="btn-return">
        ← Retourner à la liste de mes séances
    </a>
</div>

{% endblock %}