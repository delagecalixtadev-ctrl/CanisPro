{% extends 'base.html.twig' %}

{% block title %}Cours index{% endblock %}

{% block body %}
<style>
    /* Import des polices Google */
    @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@400;500;700&display=swap');

    body {
        background-color: white;
        font-family: 'Montserrat', sans-serif;
        padding: 40px;
        color: #333;
    }

    /* Titre Calligraphié */
    h1 {
        font-family: 'Great Vibes', cursive;
        text-align: center;
        font-size: 4rem;
        margin-bottom: 30px;
        color: #1a1a1a;
        font-weight: normal;
    }

    /* Conteneur de la table */
    .table-container {
        max-width: 1000px;
        margin: 0 auto;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        background-color: white;
        border: 2px solid #558394; /* Bordure extérieure bleue */
    }

    /* Header (Bleu Canard) */
    .table thead th {
        background-color: #558394;
        color: white;
        padding: 15px;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.85rem;
        border: 1px solid #7296a6;
        text-align: center;
    }

    /* Lignes et Cellules */
    .table tbody td {
        padding: 12px 15px;
        border: 1px solid #c2d1d9;
        text-align: center;
        color: #555;
        font-size: 0.85rem;
        text-transform: uppercase; /* Style "All Caps" de l'image */
    }

    /* Effet au survol des lignes */
    .table tbody tr:hover {
        background-color: #f0f4f5;
    }

    /* Style des liens d'actions */
    .actions-links a {
        text-decoration: none;
        color: #558394;
        font-weight: bold;
        margin: 0 8px;
        font-size: 0.75rem;
        border-bottom: 1px solid transparent;
        transition: all 0.3s;
    }

    .actions-links a:hover {
        border-bottom: 1px solid #558394;
        color: #3a5c69;
    }

    /* Bouton Ajouter en bas */
    .btn-create {
        display: inline-block;
        margin-top: 25px;
        padding: 12px 25px;
        background-color: #558394;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        font-weight: 500;
        transition: background 0.3s;
    }

    .btn-create:hover {
        background-color: #3f6472;
    }
</style>

<h1>Gérer les cours</h1>

<div style="text-align: center;">
    <a href="{{ path('adminAjoutCours') }}" class="btn-create">Ajouter un nouveau cours</a>
</div>
<br>
<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Type Entrainement</th>
                <th>Description</th>
                <th>Prix</th>
                <th>Collectif</th>
                <th>Chiens Max</th>
                <th>Durée</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for cour in cours %}
            <tr>
                <td>{{ cour.id }}</td>
                <td>{{ cour.typeEntrainement }}</td>
                <td>{{ cour.description }}</td>
                <td>{{ cour.prix }} €</td>
                <td>{{ cour.esCollectif ? 'OUI' : 'NON' }}</td>
                <td>{{ cour.nbChienMax }}</td>
                <td>{{ cour.duree }} min</td>
                <td class="actions-links">
                    <a href="{{ path('adminAfficheUnCours', {'id': cour.id}) }}">Voir</a>
                    <a href="{{ path('adminModifierUnCours', {'id': cour.id}) }}">Éditer</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">Aucun cours trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>



{% endblock %}